<suite name="Master Suite" verbose="1" parallel="tests" thread-count="3">

    <!-- Listeners -->
    <listeners>
        <listener class-name="utilities.ExtentReporterManager"/>
    </listeners>

    <!-- ==================== SANITY TESTS ==================== -->
    <test name="Sanity Tests">
        <parameter name="os" value="Windows"/>
        <parameter name="browser" value="chrome"/>

        <groups>
            <run>
                <include name="Sanity"/>
            </run>
        </groups>

        <classes>
            <class name="testCases.TC001_SigninTest"/>
            <class name="testCases.TC002_SigninPositiveNegativeTest"/>
        </classes>
    </test>

    <!-- ==================== REGRESSION TESTS ==================== -->
    <test name="Regression Tests">
        <parameter name="os" value="Windows"/>
        <parameter name="browser" value="chrome"/>

        <groups>
            <run>
                <include name="Regression"/>
            </run>
        </groups>

        <classes>
            <class name="testCases.TC002_SigninPositiveNegativeTest"/>
        </classes>
    </test>

    <!-- ==================== SECURITY TESTS ==================== -->
    <test name="Security Tests">
        <parameter name="os" value="Windows"/>
        <parameter name="browser" value="chrome"/>

        <groups>
            <run>
                <include name="Security"/>
            </run>
        </groups>

        <classes>
            <class name="testCases.TC002_SigninPositiveNegativeTest"/>
        </classes>
    </test>

</suite>
