<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Comprehensive Signin Test Suite - Positive and Negative Test Cases -->
<suite name="Signin Test Suite">
  
  <listeners>
	  <listener class-name="utilities.ExtentReporterManager" />
  </listeners>
  
  <test thread-count="1" name="Signin Positive Tests">
    <parameter name="os" value="Windows"/>
    <parameter name="browser" value="chrome"/>
     
    <classes>
      <class name="testCases.TC002_SigninPositiveNegativeTest">
        <methods>
          <include name="test_Signin_With_Valid_Credentials"/>
          <include name="test_Signin_Username_Case_Insensitive"/>
          <include name="test_Signin_Page_Elements_Displayed"/>
        </methods>
      </class>
    </classes>
  </test>
  
  <test thread-count="1" name="Signin Negative Tests">
    <parameter name="os" value="Windows"/>
    <parameter name="browser" value="chrome"/>
     
    <classes>
      <class name="testCases.TC002_SigninPositiveNegativeTest">
        <methods>
          <include name="test_Signin_Invalid_Username"/>
          <include name="test_Signin_Invalid_Password"/>
          <include name="test_Signin_Invalid_Both_Credentials"/>
          <include name="test_Signin_Empty_Username"/>
          <include name="test_Signin_Empty_Password"/>
          <include name="test_Signin_Both_Fields_Empty"/>
          <include name="test_Signin_SQL_Injection_Attempt"/>
          <include name="test_Signin_XSS_Attempt"/>
          <include name="test_Signin_Special_Characters_Username"/>
          <include name="test_Signin_Very_Long_Username"/>
          <include name="test_Signin_Whitespace_Username"/>
        </methods>
      </class>
    </classes>
  </test>
  
</suite>
